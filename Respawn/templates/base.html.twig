<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}GamerReddit{% endblock %}</title>
        <script src="https://cdn.tailwindcss.com"></script>
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    </head>
    <body class="bg-[#DAE0E6] text-[#1A1A1B] font-sans">
        
        {# Navbar #}
        <nav class="bg-white border-b border-gray-300 sticky top-0 z-50 px-4 py-1 flex items-center justify-between">
            <div class="flex items-center space-x-2">
                <div class="bg-orange-600 rounded-full p-2 text-white">
                    <i class="fas fa-gamepad"></i>
                </div>
                <span class="font-bold text-lg hidden md:block">Respawn</span>
            </div>
            
            <input type="text" placeholder="Rechercher un jeu..." class="bg-gray-100 border border-gray-200 rounded-md px-4 py-1 w-1/2 focus:outline-none focus:bg-white focus:border-blue-500">
            
            <div class="flex space-x-2">
                <button class="bg-blue-600 text-white font-bold px-4 py-1 rounded-full hover:bg-blue-500">Connexion</button>
            </div>
        </nav>

        <main class="max-w-6xl mx-auto flex justify-center mt-5 px-4">
            {# Flux de posts #}
            <div class="w-full md:w-2/3 space-y-4">
                {% block body %}{% endblock %}
            </div>

            {# Sidebar Droite #}
            <div class="hidden md:block w-1/3 ml-6">
                <div class="bg-white rounded-md border border-gray-300 p-3">
                    <h3 class="font-bold text-gray-500 text-xs mb-3 tracking-widest uppercase">Communautés Tendances</h3>
                    <ul class="space-y-3">
                        <li class="flex items-center justify-between text-sm">
                            <span>r/EldenRing</span>
                            <button class="text-blue-500 font-bold">Rejoindre</button>
                        </li>
                        <li class="flex items-center justify-between text-sm">
                            <span>r/Cyberpunk2077</span>
                            <button class="text-blue-500 font-bold">Rejoindre</button>
                        </li>
                    </ul>
                </div>
            </div>
        </main>
    </body>
</html>